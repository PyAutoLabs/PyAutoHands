#!/usr/bin/env bash
# autohands — unified bash CLI for PyAutoHands operations.
#
# Run `autohands help` for the list of subcommands.
# Run `autohands help <subcommand>` for full details on one subcommand.
#
# Recommended alias for ~/.bashrc:
#   alias autohands-help='$HOME/Code/PyAutoLabs/PyAutoHands/bin/autohands help'

set -u

SELF="$(readlink -f "$0")"
REPO="$(cd "$(dirname "$SELF")/.." && pwd)"
PYAUTOBASE="$(cd "$REPO/.." && pwd)"
AUTOHANDS_DIR="$REPO/autohands"
ADMIN_JAMMY="$PYAUTOBASE/admin_jammy"

# ----- subcommand registration -----
#
# SUBCOMMAND_ORDER drives the layout of `autohands help`. Entries beginning
# with "# " are rendered as section headers; everything else is a real
# subcommand and must have a matching SHORT_DESC entry plus cmd_<name> and
# help_<name> functions.

SUBCOMMAND_ORDER=(
  "# Build and release pipeline"
  pre_build
  "# Release validation"
  verify_install
  url_check
  bump_colab_urls
  "# Workspace operations (run from a workspace root)"
  generate
  run
  run_python
  run_all
  "# Release support"
  script_matrix
  aggregate_results
  slow_skip_check
  generate_release_notes
  create_analysis_issue
  tag_and_merge
  "# Triage support"
  repro_command
  "# Monitoring daemon (delegates to PyAutoHeart)"
  watch
  status
  tick
  fix
  "# Meta"
  help
)

declare -A SHORT_DESC=(
  [pre_build]="Format, generate, push workspaces, then dispatch release.yml"
  [verify_install]="Shim → pyauto-heart verify_install (deep install-path checks)"
  [url_check]="Shim → pyauto-heart url_check (forbidden Binder/Colab URL guard)"
  [bump_colab_urls]="Rewrite Colab URLs in cwd from old date-tag to new date-tag"
  [generate]="Convert workspace scripts/ to notebooks/ (run from a workspace root)"
  [run]="Execute notebooks in a workspace folder"
  [run_python]="Execute Python scripts in a workspace folder"
  [run_all]="Run scripts across one or more workspaces and produce summary reports"
  [script_matrix]="Output a JSON matrix of {name, directory} for GitHub Actions"
  [aggregate_results]="Aggregate per-job JSON results into a release-readiness report"
  [slow_skip_check]="Surface SLOW / NEEDS_FIX entries in workspace no_run.yaml files"
  [generate_release_notes]="Generate release notes from merged PRs and create GitHub Releases"
  [create_analysis_issue]="Open a GitHub issue with the release report and assign Copilot"
  [tag_and_merge]="Commit and tag every library repo for a release"
  [repro_command]="Emit the shell command autohands uses to run one script (for triage handoffs)"
  [watch]="Start the PyAutoHeart monitoring daemon (Ctrl-C to stop)"
  [status]="Print the latest PyAutoHeart state cache with green/yellow/red"
  [tick]="Force one PyAutoHeart refresh cycle"
  [fix]="Bundle context for a Heart failure topic and emit a Claude invocation"
  [help]="List subcommands or show details for one"
)

# _python_in_autohands <script> [args...]
# Run a Python tool from autohands/ with PYTHONPATH set so its sibling
# modules (build_util, generate_autofit, env_config, result_collector)
# resolve correctly. Inherits the user's cwd unchanged — several tools
# (run.py, run_python.py, generate.py) read config from cwd.
_python_in_autohands() {
  local script="$1"
  shift
  PYTHONPATH="$AUTOHANDS_DIR${PYTHONPATH:+:$PYTHONPATH}" \
    python "$AUTOHANDS_DIR/$script" "$@"
}

# ----- Build and release pipeline -----

help_pre_build() {
  cat <<'EOF'
autohands pre_build [minor_version] [skip_release]

Run black + generate notebooks + commit & push for every workspace repo,
then commit & push PyAutoHands itself, then dispatch the GitHub Actions
release.yml workflow.

For each workspace with a README package mapping (PyAutoFit / PyAutoGalaxy
/ PyAutoLens), the README is also bumped to the new release version
(YYYY.M.D.<minor>) before commit.

Arguments:
  minor_version  Minor version suffix appended to YYYY.M.D (default: 1)
  skip_release   "true" to skip the release stage (default: false)

This is the bash entry point that the /pre_build Claude skill wraps.
EOF
}
cmd_pre_build() {
  bash "$REPO/pre_build.sh" "$@"
}

# ----- Release validation -----

help_verify_install() {
  cat <<'EOF'
autohands verify_install [CHECKS...] [--version VERSION] [--keep]

Shim → `pyauto-heart verify_install`. Release-readiness checking is Heart's
job now (PyAutoHands is a pure executor), so this delegates to PyAutoHeart,
which owns the install-path checks (pip & conda, A–E) and writes the JSON
sidecar that `pyauto-heart readiness` consumes.

See `pyauto-heart help verify_install` for full docs.
EOF
}
cmd_verify_install() {
  local heart_bin
  heart_bin="$(_heart_resolve)" || return $?
  exec "$heart_bin" verify_install "$@"
}

help_url_check() {
  cat <<'EOF'
autohands url_check [directory]

Shim → `pyauto-heart url_check`. URL hygiene is PyAutoHeart's job now
(PyAutoHands is a pure executor). Scans rst/md/ipynb/py under <directory>
(default cwd) for forbidden Binder/Colab/owner URL patterns.

The ecosystem-wide sweep runs from PyAutoHeart's central url-check.yml
workflow; see `pyauto-heart help url_sweep`.
EOF
}
cmd_url_check() {
  local heart_bin
  heart_bin="$(_heart_resolve)" || return $?
  exec "$heart_bin" url_check "$@"
}

help_bump_colab_urls() {
  cat <<'EOF'
autohands bump_colab_urls <new-tag>

Rewrite every URL of the form
  colab.research.google.com/github/PyAutoLabs/<repo>/blob/<old-tag>/...
to use <new-tag>, in-place across *.rst, *.md, *.ipynb, *.py under cwd.

<repo> must be one of: autofit_workspace, autogalaxy_workspace,
autolens_workspace, HowToGalaxy, HowToLens, HowToFit.
<new-tag> must look like YYYY.M.D.B. Idempotent.

Called by the release.yml `release_workspaces` and `bump_library_colab_urls`
jobs so README/docs Colab links always pin to the just-released tag.
EOF
}
cmd_bump_colab_urls() {
  bash "$AUTOHANDS_DIR/bump_colab_urls.sh" "$@"
}

# ----- Workspace operations -----

help_generate() {
  cat <<'EOF'
autohands generate <project> [--report-dir DIR]

Convert every script in scripts/ to a Jupyter notebook in notebooks/, run
from inside the workspace root. The <project> argument selects the Colab
setup cell injected into each generated notebook.

Arguments:
  project        Project name (e.g. autofit, autogalaxy, autolens, howtolens)
  --report-dir   Directory to write structured JSON generation results to

Run from the workspace root, not from PyAutoHands.
EOF
}
cmd_generate() {
  _python_in_autohands generate.py "$@"
}

help_run() {
  cat <<'EOF'
autohands run <project> <directory> [--visualise] [--report-dir DIR] [--env-config FILE]

Execute Jupyter notebooks in <directory> for <project>, skipping files
listed in the workspace's config/build/no_run.yaml (required).

Arguments:
  project        Project name (e.g. autofit, autogalaxy, autolens)
  directory      Subdirectory of notebooks/ to execute
  --visualise    Only run notebooks listed in the workspace's
                 config/build/visualise_notebooks.yaml (selects nothing
                 if the workspace has no such file)
  --report-dir   Directory to write structured JSON results to
  --env-config   Path to env_vars.yaml for per-script environment config

Run from the workspace root.
EOF
}
cmd_run() {
  _python_in_autohands run.py "$@"
}

help_run_python() {
  cat <<'EOF'
autohands run_python <project> <directory> [--report-dir DIR] [--env-config FILE]

Execute Python scripts in <directory> for <project>, skipping files
listed in config/build/no_run.yaml.

Arguments:
  project        Project name (e.g. autofit, autogalaxy, autolens)
  directory      Subdirectory of scripts/ to execute
  --report-dir   Directory to write structured JSON results to
  --env-config   Path to env_vars.yaml for per-script environment config

Run from the workspace root.
EOF
}
cmd_run_python() {
  _python_in_autohands run_python.py "$@"
}

help_run_all() {
  cat <<'EOF'
autohands run_all [WORKSPACE...] [--results-dir DIR] [--timeout-secs N]

Run workspace scripts across one or more workspaces and produce summary
reports.

Arguments (positional):
  autofit | autogalaxy | autolens | autofit_test | autogalaxy_test | autolens_test
  | howtofit | howtogalaxy | howtolens | euclid
  (default: all ten)

Options:
  --results-dir    Override default output dir (default:
                   PyAutoHands/test_results/runs/<UTC-timestamp>/, with a
                   sibling `latest` symlink)
  --timeout-secs   Per-script timeout in seconds (default: 300)

Each workspace also gets a test_report.md in its root for easy access.
EOF
}
cmd_run_all() {
  _python_in_autohands run_all.py "$@"
}

# ----- Release support -----

help_script_matrix() {
  cat <<'EOF'
autohands script_matrix <project...>

Print a JSON matrix of {name, directory} pairs for GitHub Actions matrix
strategy. <project> arguments are workspace names whose scripts/ directory
will be enumerated.

Used by release.yml to dynamically generate the run_scripts and
run_notebooks job matrices.
EOF
}
cmd_script_matrix() {
  _python_in_autohands script_matrix.py "$@"
}

help_aggregate_results() {
  cat <<'EOF'
autohands aggregate_results <results-dir> [--output JSON] [--markdown MD]

Aggregate per-job JSON result files from <results-dir> into a consolidated
release readiness report.

Arguments:
  results-dir    Directory containing per-job *.json result files
  --output       Path to write the aggregated JSON report
  --markdown     Path to write a human-readable markdown summary

Used by the analyze_results job in release.yml.
EOF
}
cmd_aggregate_results() {
  _python_in_autohands aggregate_results.py "$@"
}

help_slow_skip_check() {
  cat <<'EOF'
autohands slow_skip_check [WORKSPACE_PATH...]

Scan workspace no_run.yaml files for entries tagged as SLOW-skips or
NEEDS_FIX-skips and surface them so they cannot be silently forgotten.

Defaults to scanning the six main workspaces under PyAutoLabs:
  autofit_workspace, autogalaxy_workspace, autolens_workspace,
  autofit_workspace_test, autolens_workspace_test.

Output is a warning banner suitable for printing in CI logs.
EOF
}
cmd_slow_skip_check() {
  _python_in_autohands slow_skip_check.py "$@"
}

help_generate_release_notes() {
  cat <<'EOF'
autohands generate_release_notes --version <VERSION> --repo <OWNER/REPO> [--dry-run]

Generate release notes from merged PRs and create GitHub Releases. For
downstream repos (PyAutoGalaxy, PyAutoLens), notes include upstream
changes from dependency repos.

Arguments:
  --version  Release version (e.g. 2026.4.20.1)
  --repo     Repository in OWNER/REPO form (e.g. PyAutoLabs/PyAutoLens)
  --dry-run  Print the release notes without creating the release
EOF
}
cmd_generate_release_notes() {
  _python_in_autohands generate_release_notes.py "$@"
}

help_create_analysis_issue() {
  cat <<'EOF'
autohands create_analysis_issue <report.json> --run-id <ID> [--repo <OWNER/REPO>] [--dry-run]

Create a GitHub Issue with the release readiness report and assign
Copilot for analysis.

Arguments:
  report.json   Path to the aggregated JSON report from aggregate_results
  --run-id      Workflow run ID to link in the issue body
  --repo        Repository in OWNER/REPO form (default inferred)
  --dry-run     Print the issue body without creating the issue
EOF
}
cmd_create_analysis_issue() {
  _python_in_autohands create_analysis_issue.py "$@"
}

help_tag_and_merge() {
  cat <<'EOF'
autohands tag_and_merge --version <VERSION>

Commit any pending changes and tag HEAD as v<VERSION> in every library
repo: PyAutoNerves, PyAutoFit, PyAutoArray, PyAutoGalaxy, PyAutoLens.

Each repo gets a commit with message "Update version to <VERSION>" and
a tag named "v<VERSION>". Stops on the first failing repo.
EOF
}
cmd_tag_and_merge() {
  bash "$AUTOHANDS_DIR/tag_and_merge.sh" "$@"
}

# ----- Triage support -----

help_repro_command() {
  cat <<'EOF'
autohands repro_command <script_path>

Print the exact shell command `autohands run_python` would have used to
execute one workspace script — including all environment variables from
the workspace's config/build/env_vars.yaml (defaults + matching
per-pattern overrides).

Intended for triage handoffs: when pasting a failing script into a chat
or issue, run this first so the reader gets a self-contained command
that reproduces the autohands failure exactly (not just `python3 <file>`,
which omits PYAUTO_TEST_MODE / PYAUTO_SMALL_DATASETS / etc.).

Arguments:
  script_path   Path to a workspace script (absolute or relative to cwd)

Output (single line, to stdout):
  (cd <workspace_name> && env KEY=val ... python3 <script_relpath>)

Run the printed command from the PyAutoLabs base directory.
EOF
}
cmd_repro_command() {
  _python_in_autohands repro_command.py "$@"
}

# ----- Monitoring daemon (delegates to PyAutoHeart) -----
#
# These four subcommands shim through to the standalone `pyauto-heart`
# binary installed from the sibling PyAutoLabs/PyAutoHeart repo. The
# split is deliberate: PyAutoHands produces releases; PyAutoHeart
# monitors developer state continuously. Co-locating the CLI surface
# (via these shims) without sharing Python code keeps both repos
# independently releasable.
#
# If `pyauto-heart` is not on PATH, the shim prints an install hint and
# exits 127.

_heart_resolve() {
  # Resolve a path/command for the pyauto-heart binary. Try:
  #   1. PATH (works if `pip install pyautoheart` made the entry point global)
  #   2. The bin script in the sibling PyAutoHeart repo checkout
  # Prints the resolved invocation on stdout, returns 0 on success.
  if command -v pyauto-heart >/dev/null 2>&1; then
    printf 'pyauto-heart'
    return 0
  fi
  local heart_bin="$HOME/Code/PyAutoLabs/PyAutoHeart/bin/pyauto-heart"
  if [[ -x "$heart_bin" ]]; then
    printf '%s' "$heart_bin"
    return 0
  fi
  cat >&2 <<EOF
autohands: pyauto-heart was not found on PATH or at the sibling checkout
$HOME/Code/PyAutoLabs/PyAutoHeart/.

PyAutoHeart is not pip-installed — like the other PyAuto repos it runs from
its checkout via PYTHONPATH + PATH in ~/.bashrc. Set it up with:
  git clone https://github.com/PyAutoLabs/PyAutoHeart.git \$HOME/Code/PyAutoLabs/PyAutoHeart
  # add to ~/.bashrc:
  #   export PATH="\$HOME/Code/PyAutoLabs/PyAutoHeart/bin:\$PATH"
  #   export PYTHONPATH="\$PYTHONPATH:\$HOME/Code/PyAutoLabs/PyAutoHeart"
  source ~/.bashrc
EOF
  return 127
}

help_watch() {
  cat <<'EOF'
autohands watch [interval_seconds]

Shim → `pyauto-heart watch`. Run the PyAutoHeart monitoring daemon in
the foreground, refreshing the cached state every N seconds (default
300s). Ctrl-C to stop.

See `pyauto-heart help watch` for full docs.
EOF
}
cmd_watch() {
  local heart_bin
  heart_bin="$(_heart_resolve)" || return $?
  exec "$heart_bin" watch "$@"
}

help_status() {
  cat <<'EOF'
autohands status [--json] [--quiet] [--no-color]

Shim → `pyauto-heart status`. Print the most recent Heart state cache
with green/yellow/red colouring. Exits non-zero if no cache exists
(run `autohands tick` first).
EOF
}
cmd_status() {
  local heart_bin
  heart_bin="$(_heart_resolve)" || return $?
  exec "$heart_bin" status "$@"
}

help_tick() {
  cat <<'EOF'
autohands tick

Shim → `pyauto-heart tick`. Force one PyAutoHeart refresh cycle: every
check (repo state, CI status, open PRs, worktree drift, script
timing) runs and the aggregated snapshot is written.
EOF
}
cmd_tick() {
  local heart_bin
  heart_bin="$(_heart_resolve)" || return $?
  exec "$heart_bin" tick "$@"
}

help_fix() {
  cat <<'EOF'
autohands fix <topic> [args...]

Shim → `pyauto-heart fix`. Bundle context for a specific failing topic
and emit a Claude Code invocation you can paste/run.

Topics:
  ci <repo>         the latest red CI run on that repo
  drift             current worktree drift
  timing <project>  script timing regressions for that project
EOF
}
cmd_fix() {
  local heart_bin
  heart_bin="$(_heart_resolve)" || return $?
  exec "$heart_bin" fix "$@"
}

# ----- Meta -----

help_help() {
  cat <<'EOF'
autohands help [subcommand]

With no argument, list every subcommand with a one-line description.
With a subcommand, print the full docstring for that subcommand.
EOF
}
cmd_help() {
  if [ $# -eq 0 ]; then
    cat <<'EOF'
autohands — unified CLI for PyAutoHands operations.

Usage: autohands <subcommand> [args...]
       autohands help [subcommand]
       autohands <subcommand> --help

Subcommands:
EOF
    local entry
    for entry in "${SUBCOMMAND_ORDER[@]}"; do
      if [[ "$entry" == "#"* ]]; then
        printf '\n  %s\n' "${entry#\# }"
      else
        printf '    %-28s %s\n' "$entry" "${SHORT_DESC[$entry]:-}"
      fi
    done
    cat <<'EOF'

Run `autohands help <subcommand>` to see full documentation.
EOF
    return 0
  fi

  local name="$1"
  if ! declare -f "help_$name" > /dev/null; then
    echo "autohands: unknown subcommand '$name'" >&2
    echo "Run 'autohands help' for the list of subcommands." >&2
    return 2
  fi
  "help_$name"
}

# ----- dispatcher -----

main() {
  local sub="${1:-}"
  case "$sub" in
    ""|-h|--help|help)
      shift 2>/dev/null || true
      cmd_help "$@"
      return $?
      ;;
  esac
  shift
  if ! declare -f "cmd_$sub" > /dev/null; then
    echo "autohands: unknown subcommand '$sub'" >&2
    echo "Run 'autohands help' for the list of subcommands." >&2
    return 2
  fi
  case "${1:-}" in
    -h|--help)
      "help_$sub"
      return 0
      ;;
  esac
  "cmd_$sub" "$@"
}

main "$@"
